{
    "ui_type": "flow",
    "ui_meta": {
        "schema_version": "1",
        "flow": {
            "intent_id": "agenda.crear-agenda-flow",
            "mode": "conversational",
            "entry_subintent_id": "select_rrhh",
            "draft_keys": [
                "id_rr_hh",
                "id_servicio"
            ],
            "open_ui_hints": {
                "select_rrhh": {
                    "action_id": "rrhh.listar-por-efector-ui"
                },
                "select_servicio": {
                    "action_id": "rrhh.listar-servicios-asignados"
                },
                "open_wizard": {
                    "action_id": "agenda.editar-agenda"
                }
            },
            "steps": [
                {
                    "id": "select_rrhh",
                    "assistant_text": "Elegí el profesional al que querés crearle (o completarle) la agenda.",
                    "requires": [
                        "draft.id_rr_hh"
                    ],
                    "provides": [
                        "draft.id_rr_hh"
                    ],
                    "next": "select_servicio",
                    "ui": {
                        "default_tab": "default",
                        "tabs": [
                            {
                                "id": "default",
                                "label": "Elegir",
                                "action_id": "rrhh.listar-por-efector-ui",
                                "route": "/api/v1/rrhh/listar-por-efector-ui",
                                "params": {},
                                "requires_client": []
                            }
                        ]
                    }
                },
                {
                    "id": "select_servicio",
                    "assistant_text": "Ahora elegí el servicio asignado.",
                    "requires": [
                        "draft.id_rr_hh",
                        "draft.id_servicio"
                    ],
                    "provides": [
                        "draft.id_servicio"
                    ],
                    "next": "open_wizard",
                    "ui": {
                        "default_tab": "default",
                        "tabs": [
                            {
                                "id": "default",
                                "label": "Elegir",
                                "action_id": "rrhh.listar-servicios-asignados",
                                "route": "/api/v1/rrhh/listar-servicios-asignados",
                                "params": {
                                    "id_rr_hh": "draft.id_rr_hh"
                                },
                                "requires_client": []
                            }
                        ]
                    }
                },
                {
                    "id": "open_wizard",
                    "assistant_text": "Listo. Abrí la pantalla para cargar la agenda (horarios y condición laboral).",
                    "requires": [
                        "draft.id_rr_hh",
                        "draft.id_servicio"
                    ],
                    "provides": [],
                    "next": "",
                    "ui": {
                        "default_tab": "default",
                        "tabs": [
                            {
                                "id": "default",
                                "label": "Elegir",
                                "action_id": "agenda.editar-agenda",
                                "route": "/api/v1/agenda/editar-agenda",
                                "params": {
                                    "id_rr_hh": "draft.id_rr_hh",
                                    "id_servicio": "draft.id_servicio"
                                },
                                "requires_client": []
                            }
                        ]
                    }
                }
            ]
        },
        "assistant_embed": {},
        "clients": {
            "*": {
                "min_app_version": "1.0.0"
            }
        }
    },
    "wizard_config": {
        "title": "Reservar turno (flujo por chat)",
        "steps": [
            {
                "step": 0,
                "title": "Guía",
                "fields": [
                    "_flow_notice"
                ]
            }
        ],
        "fields": [
            {
                "name": "_flow_notice",
                "label": "Cómo continuar",
                "type": "textarea",
                "required": false,
                "value": "Este flujo ya no es un wizard monolítico: el asistente te va pidiendo cada dato y, cuando corresponda, embebe mini-UIs (por ejemplo, elegir efector). Si ves esto en una pantalla legacy, actualizá el cliente para renderizar `ui_type=flow` + `ui_meta.flow`."
            }
        ]
    }
}
