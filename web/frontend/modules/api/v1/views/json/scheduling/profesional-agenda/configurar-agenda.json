{
  "ui_type": "ui_json",
  "ui_meta": {
    "schema_version": "1",
    "field_meta": {
      "vigente_desde": {
        "impact_profile": "grid",
        "hint": "Los turnos anteriores a esta fecha no se modifican. Desde esta fecha se evalúa el impacto si cambiás horarios o intervalo."
      },
      "intervalo_minutos": { "impact_profile": "grid" },
      "lunes_2": { "impact_profile": "grid", "form": false },
      "martes_2": { "impact_profile": "grid", "form": false },
      "miercoles_2": { "impact_profile": "grid", "form": false },
      "jueves_2": { "impact_profile": "grid", "form": false },
      "viernes_2": { "impact_profile": "grid", "form": false },
      "sabado_2": { "impact_profile": "grid", "form": false },
      "domingo_2": { "impact_profile": "grid", "form": false },
      "cupo_pacientes": { "impact_profile": "capacity" },
      "formas_atencion": { "impact_profile": "capacity" },
      "acepta_consultas_online": { "impact_profile": "none" }
    },
    "clients": {
      "*": { "min_app_version": "1.0.0" }
    }
  },
  "blocks": [
    {
      "kind": "fields",
      "id": "datos",
      "title": "Configuración de agenda",
      "fields": [
        {
          "name": "ui_step",
          "label": "",
          "type": "hidden",
          "value": "datos",
          "include_in_submit": true
        },
        {
          "name": "id_efector",
          "label": "",
          "type": "hidden",
          "required": false
        },
        {
          "name": "id_profesional_efector_servicio",
          "label": "",
          "type": "hidden",
          "required": false,
          "include_in_submit": true
        },
        {
          "name": "id_servicio",
          "label": "",
          "type": "hidden",
          "required": true,
          "include_in_submit": true
        },
        {
          "name": "vigente_desde",
          "label": "¿Desde qué fecha aplica este cambio?",
          "type": "date",
          "required": true,
          "layout": { "col": 4, "breakpoint": "md" }
        },
        {
          "name": "intervalo_minutos",
          "label": "Minutos por turno",
          "type": "select",
          "required": true,
          "options": [
            { "value": "15", "label": "15 minutos" },
            { "value": "20", "label": "20 minutos" },
            { "value": "30", "label": "30 minutos" },
            { "value": "45", "label": "45 minutos" },
            { "value": "60", "label": "60 minutos" }
          ],
          "layout": { "col": 4, "breakpoint": "md" }
        },
        {
          "name": "cupo_pacientes",
          "label": "Cupo de pacientes (límite diario)",
          "type": "select",
          "required": false,
          "options": [
            { "value": "0", "label": "Sin cupo" },
            { "value": "5", "label": "5" },
            { "value": "10", "label": "10" },
            { "value": "15", "label": "15" },
            { "value": "20", "label": "20" },
            { "value": "25", "label": "25" },
            { "value": "30", "label": "30" }
          ],
          "layout": { "col": 4, "breakpoint": "md" }
        },
        {
          "name": "formas_atencion",
          "label": "Forma de atención de turnos",
          "type": "select",
          "required": true,
          "options": [
            { "value": "ORDEN_LLEGADA", "label": "Orden de llegada" },
            { "value": "TURNO", "label": "Programado" },
            { "value": "SIN_ATENCION", "label": "Sin atención por turnos" }
          ],
          "layout": { "col": 6, "breakpoint": "md" }
        },
        {
          "name": "acepta_consultas_online",
          "label": "Acepto teleconsulta (videollamada) en esta agenda",
          "type": "select",
          "required": false,
          "include_in_submit": true,
          "options": [
            { "value": "0", "label": "No" },
            { "value": "1", "label": "Sí" }
          ],
          "layout": { "col": 6, "breakpoint": "md" }
        },
        {
          "name": "weekly_scheduler_widget",
          "label": "Horarios por día",
          "type": "custom_widget",
          "widget_id": "weekly_scheduler",
          "required": false,
          "value_fields": [
            "lunes_2",
            "martes_2",
            "miercoles_2",
            "jueves_2",
            "viernes_2",
            "sabado_2",
            "domingo_2"
          ],
          "assets": {
            "css": ["/css/scheduler.css"],
            "js": ["/js/scheduler.js", "/js/widgets/ui-widget-weekly-scheduler.js"]
          }
        }
      ]
    }
  ]
}
