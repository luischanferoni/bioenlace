# Vendor y dependencias
/vendor
# Importante: en apps (Yii2) el lock NO se ignora; asegura deploys reproducibles.
# `composer install` en producción debe respetar este archivo.

# Yii Framework
/yii
/yii.bat
/yii_test

# Archivos de configuración sensibles
frontend/web/index.php
frontend/web/index-test.php
frontend/web/robots.txt
admin/web/index.php
admin/web/index-test.php
admin/web/robots.txt

# Uploads y archivos generados por usuarios
frontend/web/uploads/*
frontend/web/practicas/*
admin/web/uploads/*

# Runtime y cache
frontend/runtime/*
admin/runtime/*
console/runtime/*
admin/web/assets

# Logs
frontend/runtime/logs/analisis-consultas/*.log

# Archivos de producción/backup
/BD backup
/produccion/sisse-56/*.csv
/produccion/sisse-56/*.sql

# Herramientas de desarrollo
.php-cs-fixer.cache
/nbproject/private/

# Credenciales y archivos sensibles
/config/credentials/
**/credentials/*.json
**/credentials/*.key
**/credentials/*.pem
*.json
!composer.json
!package.json
# Excluir descriptores UI JSON (módulo API v1) del ignore global *.json
!frontend/modules/api/v1/views/json/**/*.json
# Conversaciones de prueba para costos de IA
!common/data/conversaciones/**/*.json