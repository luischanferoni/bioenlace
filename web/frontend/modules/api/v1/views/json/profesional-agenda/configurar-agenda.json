{
  "ui_type": "ui_json",
  "ui_meta": {
    "schema_version": "1",
    "clients": {
      "*": {
        "min_app_version": "1.0.0"
      }
    }
  },
  "blocks": [
    {
      "kind": "fields",
      "id": "default",
      "fields": [
        {
          "name": "id_efector",
          "label": "",
          "type": "hidden",
          "required": false
        },
        {
          "name": "id_profesional_efector_servicio",
          "label": "",
          "type": "hidden",
          "required": false,
          "include_in_submit": true
        },
        {
          "name": "id_servicio",
          "label": "",
          "type": "hidden",
          "required": true,
          "include_in_submit": true
        },
        {
          "name": "vigente_desde",
          "label": "Vigente desde",
          "type": "date",
          "required": true,
          "layout": { "col": 4, "breakpoint": "md" }
        },
        {
          "name": "intervalo_minutos",
          "label": "Minutos por turno",
          "type": "select",
          "required": true,
          "options": [
            { "value": "15", "label": "15 minutos" },
            { "value": "20", "label": "20 minutos" },
            { "value": "30", "label": "30 minutos" },
            { "value": "45", "label": "45 minutos" },
            { "value": "60", "label": "60 minutos" }
          ],
          "layout": { "col": 4, "breakpoint": "md" }
        },
        {
          "name": "cupo_pacientes",
          "label": "Cupo de pacientes (límite diario)",
          "type": "select",
          "required": false,
          "options": [
            { "value": "0", "label": "Sin cupo" },
            { "value": "5", "label": "5" },
            { "value": "10", "label": "10" },
            { "value": "15", "label": "15" },
            { "value": "20", "label": "20" },
            { "value": "25", "label": "25" },
            { "value": "30", "label": "30" }
          ],
          "layout": { "col": 4, "breakpoint": "md" }
        },
        {
          "name": "formas_atencion",
          "label": "Forma de atención de turnos",
          "type": "select",
          "required": true,
          "options": [
            { "value": "ORDEN_LLEGADA", "label": "Orden de llegada" },
            { "value": "TURNO", "label": "Programado" },
            { "value": "SIN_ATENCION", "label": "Sin atención por turnos" }
          ],
          "layout": { "col": 6, "breakpoint": "md" }
        },
        {
          "name": "confirmar_cambios",
          "label": "Confirmo el cambio tras revisar el impacto en turnos futuros",
          "type": "select",
          "required": false,
          "options": [
            { "value": "0", "label": "No" },
            { "value": "1", "label": "Sí, guardar" }
          ],
          "layout": { "col": 6, "breakpoint": "md" }
        },
        {
          "name": "agenda_impact_preview",
          "label": "Impacto en turnos futuros",
          "type": "custom_widget",
          "widget_id": "agenda_config_preview",
          "required": false,
          "assets": {
            "js": ["/js/widgets/ui-widget-agenda-config-preview.js"]
          },
          "layout": { "col": 12, "breakpoint": "md" }
        },
        {
          "name": "weekly_scheduler_widget",
          "label": "Horarios por día",
          "type": "custom_widget",
          "widget_id": "weekly_scheduler",
          "required": false,
          "value_fields": [
            "lunes_2",
            "martes_2",
            "miercoles_2",
            "jueves_2",
            "viernes_2",
            "sabado_2",
            "domingo_2"
          ],
          "assets": {
            "css": ["/css/scheduler.css"],
            "js": ["/js/scheduler.js", "/js/widgets/ui-widget-weekly-scheduler.js"]
          }
        }
      ]
    }
  ]
}
