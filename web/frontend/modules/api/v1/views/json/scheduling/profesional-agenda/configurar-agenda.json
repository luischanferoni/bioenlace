{
  "ui_type": "ui_json",
  "ui_meta": {
    "schema_version": "1",
    "turno_policy": {
      "grid_fields_trigger_preview": true,
      "modality_fields_direct_save": true,
      "conflict_outcome": "EN_RESOLUCION",
      "conflict_resolution": "El paciente recibe aviso y puede reubicar en otro horario con el mismo profesional o cancelar.",
      "intervalo_max_cambios_anio": 2,
      "intervalo_valores_minutos": [15, 20, 30, 45, 60]
    },
    "field_meta": {
      "vigente_desde": {
        "impact_profile": "grid",
        "turno_impact": "context",
        "hint": "Define desde qué fecha rige la nueva grilla. Los turnos anteriores no se modifican; solo se evalúan los pendientes con fecha igual o posterior."
      },
      "intervalo_minutos": {
        "impact_profile": "grid",
        "turno_impact": "grid",
        "hint": "Espaciado entre cupos reservables (15–60 min). Cambiarlo puede desalinear turnos futuros y cuenta para el límite de 2 cambios de intervalo por año."
      },
      "lunes_2": { "impact_profile": "grid", "turno_impact": "grid", "form": false },
      "martes_2": { "impact_profile": "grid", "turno_impact": "grid", "form": false },
      "miercoles_2": { "impact_profile": "grid", "turno_impact": "grid", "form": false },
      "jueves_2": { "impact_profile": "grid", "turno_impact": "grid", "form": false },
      "viernes_2": { "impact_profile": "grid", "turno_impact": "grid", "form": false },
      "sabado_2": { "impact_profile": "grid", "turno_impact": "grid", "form": false },
      "domingo_2": { "impact_profile": "grid", "turno_impact": "grid", "form": false },
      "weekly_scheduler_widget": {
        "impact_profile": "grid",
        "turno_impact": "grid"
      },
      "formas_atencion": {
        "impact_profile": "capacity",
        "turno_impact": "none",
        "hint": "Modalidad operativa del servicio (programado, orden de llegada, etc.). No mueve turnos existentes."
      },
      "acepta_consultas_online": {
        "impact_profile": "none",
        "turno_impact": "none",
        "hint": "Habilita teleconsulta en nuevas reservas elegibles. No altera turnos ya confirmados."
      }
    },
    "clients": {
      "*": { "min_app_version": "1.0.0" }
    }
  },
  "blocks": [
    {
      "kind": "message",
      "id": "policy_turnos",
      "text": "Si modificás horarios semanales o el intervalo entre turnos, el sistema revisa los turnos pendientes desde la fecha de vigencia. Los que ya no encajan en la grilla pasan a «en resolución»: el paciente recibe aviso para elegir otro horario con el mismo profesional o cancelar. Forma de atención y teleconsulta se guardan sin ese recorrido porque no desplazan turnos reservados."
    },
    {
      "kind": "fields",
      "id": "datos",
      "title": "Configuración de agenda",
      "fields": [
        {
          "name": "ui_step",
          "label": "",
          "type": "hidden",
          "value": "datos",
          "include_in_submit": true
        },
        {
          "name": "id_efector",
          "label": "",
          "type": "hidden",
          "required": false
        },
        {
          "name": "id_profesional_efector_servicio",
          "label": "",
          "type": "hidden",
          "required": false,
          "include_in_submit": true
        },
        {
          "name": "id_servicio",
          "label": "",
          "type": "hidden",
          "required": true,
          "include_in_submit": true
        },
        {
          "name": "vigente_desde",
          "label": "¿Desde qué fecha aplica este cambio?",
          "type": "date",
          "required": true,
          "layout": { "col": 6, "breakpoint": "md" }
        },
        {
          "name": "intervalo_minutos",
          "label": "Intervalo entre turnos",
          "type": "select",
          "required": true,
          "options": [
            { "value": "15", "label": "15 minutos" },
            { "value": "20", "label": "20 minutos" },
            { "value": "30", "label": "30 minutos" },
            { "value": "45", "label": "45 minutos" },
            { "value": "60", "label": "60 minutos" }
          ],
          "layout": { "col": 6, "breakpoint": "md" }
        },
        {
          "name": "weekly_scheduler_widget",
          "label": "Horarios por día (grilla de turnos)",
          "type": "custom_widget",
          "widget_id": "weekly_scheduler",
          "required": false,
          "value_fields": [
            "lunes_2",
            "martes_2",
            "miercoles_2",
            "jueves_2",
            "viernes_2",
            "sabado_2",
            "domingo_2"
          ],
          "assets": {
            "css": ["/css/scheduler.css"],
            "js": ["/js/scheduler.js", "/js/widgets/ui-widget-weekly-scheduler.js"]
          },
          "layout": { "col": 12, "breakpoint": "md" }
        },
        {
          "name": "formas_atencion",
          "label": "Forma de atención",
          "type": "select",
          "required": true,
          "options": [
            { "value": "ORDEN_LLEGADA", "label": "Orden de llegada" },
            { "value": "TURNO", "label": "Programado" },
            { "value": "SIN_ATENCION", "label": "Sin atención por turnos" }
          ],
          "layout": { "col": 6, "breakpoint": "md" }
        },
        {
          "name": "acepta_consultas_online",
          "label": "Teleconsulta en esta agenda",
          "type": "select",
          "required": false,
          "include_in_submit": true,
          "options": [
            { "value": "0", "label": "No" },
            { "value": "1", "label": "Sí" }
          ],
          "layout": { "col": 6, "breakpoint": "md" }
        }
      ]
    }
  ]
}
